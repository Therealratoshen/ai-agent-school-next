# AI Agent School — Environment Variables
# Copy this to .env.local and fill in your values

# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── AI Teacher (LLM for the AI chat teacher) ────────────────────────────────
# Options: "openai", "anthropic", "minimax", "local"
AI_TEACHER_PROVIDER=openai
OPENAI_API_KEY=sk-...           # Required if AI_TEACHER_PROVIDER=openai
ANTHROPIC_API_KEY=sk-ant-...     # Required if AI_TEACHER_PROVIDER=anthropic
MINIMAX_API_KEY=...               # Required if AI_TEACHER_PROVIDER=minimax

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
